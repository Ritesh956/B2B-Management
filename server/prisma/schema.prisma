datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  FINANCE
  PROCUREMENT
  MANAGER
  VENDOR
}

enum UserStatus {
  INVITED
  ACTIVE
  INACTIVE
}

enum VendorStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  TERMINATED
}

enum POStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CLOSED
}

enum InvoiceStatus {
  SUBMITTED
  MATCHED
  MISMATCHED
  APPROVED
  PAID
}

enum AuthTokenPurpose {
  PASSWORD_RESET
  INVITE
  // 2FA login codes. Previously kept in an in-memory Map, which Render's
  // free-tier sleep/restart wiped mid-login — the OTP a user was emailed
  // no longer existed by the time they typed it in.
  OTP_LOGIN
}

model User {
  id                      String   @id @default(uuid())
  name                    String
  email                   String   @unique
  password                String
  role                    Role
  notificationPreferences Json?
  isTwoFactorEnabled      Boolean  @default(false)
  status                  UserStatus @default(ACTIVE)
  lastLogin               DateTime?
  isActive                Boolean    @default(true)
  createdAt               DateTime @default(now())
  deletedAt               DateTime?

  purchaseOrders PurchaseOrder[] @relation("CreatedBy")
  auditLogs      AuditLog[]
  notifications  Notification[]
  authTokens     AuthToken[]

  @@index([email])
}

// Backs the password-reset and user-invite flows. Both previously stored
// their tokens in a plain in-memory Map, which is wiped on every deploy/
// restart/scale event - on Render's free tier (which sleeps after ~15min
// idle) that meant a reset or invite link was routinely dead by the time
// its recipient clicked it. Persisting here survives restarts.
model AuthToken {
  id        String           @id @default(uuid())
  token     String           @unique
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  purpose   AuthTokenPurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([token])
  @@index([userId])
}


model Vendor {
  id               String       @id @default(uuid())
  companyName      String
  contactName      String
  email            String       @unique
  phone            String
  status           VendorStatus @default(PENDING)
  documents        Json?
  performanceScore Float?       @default(0.0)
  createdAt        DateTime     @default(now())
  deletedAt        DateTime?

  contracts      Contract[]
  purchaseOrders PurchaseOrder[]
  invoices       Invoice[]

  @@index([email])
  @@index([status])
}

model Contract {
  id        String         @id @default(uuid())
  vendorId  String
  vendor    Vendor         @relation(fields: [vendorId], references: [id])
  title     String
  startDate DateTime
  endDate   DateTime
  fileUrl   String?
  status    ContractStatus @default(ACTIVE)
  createdAt DateTime       @default(now())
  deletedAt DateTime?

  @@index([vendorId])
  @@index([status, endDate])
  @@index([endDate])
}

model PurchaseOrder {
  id                   String   @id @default(uuid())
  poNumber             String   @unique @default(uuid())
  vendorId             String
  vendor               Vendor   @relation(fields: [vendorId], references: [id])
  createdById          String
  createdBy            User     @relation("CreatedBy", fields: [createdById], references: [id])
  status               POStatus @default(DRAFT)
  items                Json
  totalAmount          Float
  approvalChain        Json?
  currentApproverIndex Int      @default(0)
  createdAt            DateTime @default(now())
  deletedAt            DateTime?

  invoices Invoice[]

  @@index([vendorId])
  @@index([createdById])
  @@index([status])
  @@index([createdAt])
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  poId          String
  po            PurchaseOrder @relation(fields: [poId], references: [id])
  vendorId      String
  vendor        Vendor        @relation(fields: [vendorId], references: [id])
  amount        Float
  status        InvoiceStatus @default(SUBMITTED)
  fileUrl       String?
  submittedAt   DateTime      @default(now())
  deletedAt     DateTime?

  @@index([poId])
  @@index([vendorId])
  @@index([status])
  @@index([submittedAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  // Optional deep-link target so the client can navigate straight to the
  // record a notification is about, instead of just showing inert text.
  entity    String?
  entityId  String?

  @@index([userId])
  @@index([userId, read])
  @@index([userId, createdAt])
}
